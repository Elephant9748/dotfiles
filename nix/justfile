set quiet
bangbash := '#!/usr/bin/env bash'

# checking nix lang syntax before build or install
check $path:
        nix-instantiate --parse-only {{path}}

# list available machine 
machine:
        grep -E '\s\w{2,8}\s=\s{' flake.nix | tail -n 3 |  \
                sed -E 's/\s=\s\{//' | paste -sd "" | \
                awk '{print "\033[0;34mMachine:\033[0;32m\n\t"$1"\n\t"$2"\n\t"$3}'
# pkgs nix-env -iA nixos.<pkgs> (git, just, fish, neovim)
tools:
        nix-env -iA nixos.git nixos.neovim nixos.fish nixos.just
# clean nix-collect-garbage -d
clean:
        nix-collect-garbage -d
# show available configurations
show:
        nix flake show  --experimental-features 'nix-command flakes'
# generate nixos config on this machine
gen:
        nixos-generate-config --root /mnt
# install nixos with flake
install $machine:
        {{bangbash}}
        nixos-install --flake .#{{machine}} --verbose
# rebuild nixos with flake apply now live
build $machine:
        {{bangbash}}
        sudo nixos-rebuild switch --flake .#{{machine}}
# rebuild nixos with flake apply on next boot
build-later $machine:
        {{bangbash}}
        sudo nixos-rebuild boot --flake .#{{machine}}
# flake update
flake-up:
        nix flake update

# change user for x machine flake.nix
flake-user $machine $user:
        {{bangbash}}
        sed -i '/{{machine}} = {/,/};/ s/user =.*/user = "{{user}}";/' flake.nix
        rg "user = " flake.nix | head -n 3 | \
                paste -sd "" | \
                awk '{print "\033[0;34mvm:\033[0;32m "$1 $2 $3"\n""\033[0;34mnotebook:\033[0;32m "$4 $5 $6"\n""\033[0;34mpc:\033[0;32m "$7 $8 $9}'
# change host for x machine flake.nix
flake-host $machine $host:
        {{bangbash}}
        sed -i '/{{machine}} = {/,/};/ s/host =.*/host = "{{host}}";/' flake.nix
        rg "host = " flake.nix | head -n 3 | \
                paste -sd "" | \
                awk '{print "\033[0;34mvm:\033[0;32m "$1 $2 $3"\n""\033[0;34mnotebook:\033[0;32m "$4 $5 $6"\n""\033[0;34mpc:\033[0;32m "$7 $8 $9}'
# change machine base = minimal, full = with gui
flake-full $machine:
        {{bangbash}}
        sed -i 's/base/full/' modules/{{machine}}/default.nix
        sed -i 's/base/full/' modules/home/{{machine}}/default.nix
        printf "\033[0;34mflake-full:\n"
        rg -i "full" modules/{{machine}}/default.nix | head -n 1 | \
                paste -sd "" | awk '{print "\033[0;32m" $0}'
        rg -i "full" modules/home/{{machine}}/default.nix | head -n 1 | \
                paste -sd "" | awk '{print "\033[0;32m" $0}'
        # sed -i 's/_base.nix/_full.nix/' flake.nix
        # sed -i 's/_home_base.nix/_home_full.nix/' flake.nix
        # printf "\033[0;34m> Done look flake.nix\n\033[0m"
        # rg -i "\{label\}_" flake.nix | head -n 2 | \
        #         paste -sd "" | \
        #         awk '{print "\033[0;34mflake-full:\033[0;32m""\n\t"$1 $2"\n\t"$3}'
# change machine base = minimal, full = with gui
flake-base $machine:
        {{bangbash}}
        sed -i 's/full/base/' modules/{{machine}}/default.nix
        sed -i 's/full/base/' modules/home/{{machine}}/default.nix
        printf "\033[0;34mflake-full:\n"
        rg -i "base" modules/{{machine}}/default.nix | head -n 1 | \
                paste -sd "" | awk '{print "\033[0;32m" $0}'
        rg -i "base" modules/home/{{machine}}/default.nix | head -n 1 | \
                paste -sd "" | awk '{print "\033[0;32m" $0}'
        # sed -i 's/_full.nix/_base.nix/' flake.nix
        # sed -i 's/_home_full.nix/_home_base.nix/' flake.nix
        # printf "\033[0;34m> Done look flake.nix\n\033[0m"
        # rg -i "\{label\}_" flake.nix | head -n 2 | \
        #         paste -sd "" | \
        #         awk '{print "\033[0;34mflake-base:\033[0;32m""\n\t"$1 $2"\n\t"$3}'
# mv compositor to mangowm
flake-mango $machine:
        {{bangbash}}
        sed -i 's/# mangowm.nixosModules.mango/mangowm.nixosModules.mango/' flake.nix
        sed -i 's/exec start-hyprland/# exec start-hyprland/' modules/vm/full.nix
        sed -i 's/# exec mango/exec mango/' modules/vm/full.nix
        sed -i 's/# mango.enable = true;/mango.enable = true;/' modules/vm/full.nix
        sed -i 's/# ..\/mangowm.nix/..\/mangowm.nix/' modules/home/vm/full.nix
        sed -i 's/..\/hyprpaper.nix/# ..\/hyprpaper.nix/' modules/home/vm/full.nix
# default comopositor hyprland
flake-hypr $machine:
        {{bangbash}}
        sed -i 's/mangowm.nixosModules.mango/# mangowm.nixosModules.mango/' flake.nix
        sed -i 's/exec mango/# exec mango/' modules/vm/full.nix
        sed -i 's/# exec start-hyprland/exec start-hyprland/' modules/vm/full.nix
        sed -i 's/mango.enable = true;/# mango.enable = true;/' modules/vm/full.nix
        sed -i 's/..\/mangowm.nix/# ..\/mangowm.nix/' modules/home/vm/full.nix
        sed -i 's/# ..\/hyprland.nix/..\/hyprland.nix/' modules/home/vm/full.nix
        sed -i 's/# ..\/hyprpaper.nix/..\/hyprpaper.nix/' modules/home/vm/full.nix
# rsync fish config to host manual
to-host-fish $user:
        #!/usr/bin/env bash
        if [[ ! -d "$HOME/.config/base16-shell" ]]; then
                git clone https://github.com/chriskempson/base16-shell.git ~/.config/base16-shell
        fi
        if command -v rsync &> /dev/null; then
                if [ "{{user}}" == "root" ]; then
                        sudo rsync -azP ../configs/.config/fish /root/.config/
                else
                        rsync -azP ../configs/.config/fish $HOME/.config/
                fi
        else
                echo "rsync command not found!"
        fi
# rsync nvim config to host manual
to-host-nvim $user:
        #!/usr/bin/env bash
        if command -v rsync &> /dev/null; then
                if [ "{{user}}" == "root" ]; then
                        sudo rsync -azP ../configs/.config/nvim /root/.config/
                else
                        rsync -azP ../configs/.config/nvim $HOME/.config/
                fi
        else
                echo "rsync command not found!"
        fi
# Partitioning disk lvm on luks "/dev/sdX|vdx|nvmX"
nixos-disk-lvm-on-luks $block:
        #!/run/current-system/sw/bin/bash
        read -p $'\033[0;31mMake sure your \033[0;33m{{block}} \033[0;31mwill destroy y/n? : ' confirm
        if [ "n" == $confirm ]; then
                exit
        fi
        printf "\033[0;31m:: Destroy drive\n\033[0m"
        # wipe disk
        wipefs -a {{block}}
        # destroy GPT & MBR data structure
        sgdisk --zap-all {{block}}
        # EFI
        sgdisk -n 1:1m:+1G -t 1:ef00 -c 1:EFI {{block}}
        # swap partition
        # sgdisk -n 2:0:+4G -t 2:8200 -c 2:SWAP {{block}}
        # ZFS
        sgdisk -n 2:0:0 -t 2:8309 -c 2:NIXLUKS {{block}}

        printf "\033[0;33m:: Create Luks\n\033[0m"
        cryptsetup luksFormat --label NIX_LUKS "{{block}}2"
        printf "\033[0;32m:: Open Luks\n\033[0m"
        cryptsetup open "{{block}}2" Luks

        pvcreate /dev/mapper/Luks
        vgcreate vg_nix /dev/mapper/Luks
        # lvcreate -L 4G -n swap $vg
        # lvcreate -L 32G -n root $vg
        lvcreate -l 100%FREE -n nix_root vg_nix
        lsblk -f
        printf "\033[0;33m:: Formatting\n\033[0m"
        mkfs.fat -F32 -n EFI_BOOT "{{block}}1"
        mkfs.ext4 -L NIX_LVM /dev/vg_nix/nix_root
        printf "\033[0;33m:: Mount\n\033[0m"
        mount /dev/vg_nix/nix_root /mnt
        mount --mkdir "{{block}}1" /mnt/boot
        lsblk -f

# rsync dotfiles nix to host
to-host-nix:
        #!/run/current-system/sw/bin/bash
        # clone base16shell color
        if [[ ! -d "$HOME/.config/base16-shell" ]]; then
                git clone https://github.com/chriskempson/base16-shell.git ~/.config/base16-shell 
        fi

        if command -v rsync &> /dev/null; then
                rsync -azP ../configs/.config/alacritty $HOME/.config/ && \
                rsync -azP ../configs/.config/bspwm $HOME/.config/ && \
                rsync -azP ../configs/.config/fish $HOME/.config/ && \
                rsync -azP ../configs/.config/nvim $HOME/.config/ && \
                rsync -azP ../configs/.config/polybar $HOME/.config/ && \
                rsync -azP ../configs/.config/rofi $HOME/.config/ && \
                rsync -azP ../configs/.config/sxhkd $HOME/.config/ && \
                # rsync -azP ../configs/.config/waybar $HOME/.config/ && \
                # rsync -azP ../configs/.config/hypr $HOME/.config/ && \
                rsync -azP ../configs/.config/swappy $HOME/.config/ && \
                rsync -azP ../configs/.config/dunst $HOME/.config/ && \
                rsync -azP ../configs/.config/yazi $HOME/.config/ && \
                rsync -azP ../configs/.config/gtk-3.0 $HOME/.config/ && \
                rsync -azP ../configs/.config/gtk-4.0 $HOME/.config/ && \
                rsync -azP ../configs/.config/bottom $HOME/.config/ && \
                rsync -azP ../configs/.config/bat $HOME/.config/ && \
                # theme
